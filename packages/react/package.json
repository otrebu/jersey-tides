{
  "name": "@u-b/tides-react",
  "version": "0.1.0",
  "description": "React tide widget for @u-b/tides-core with the ubtide theming contract",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "keywords": [
    "tides",
    "react",
    "widget",
    "jersey",
    "st-helier"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otrebu/jersey-tides.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/otrebu/jersey-tides#readme",
  "bugs": {
    "url": "https://github.com/otrebu/jersey-tides/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsdown && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "test": "TZ=UTC vitest run && TZ=America/New_York vitest run"
  },
  "dependencies": {
    "@u-b/tides-core": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
